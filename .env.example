# ============================================================
# VaultX Configuration
# ============================================================

# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
MAX_CONTENT_LENGTH=10485760  # 10MB in bytes

# ============================================================
# Encryption
# ============================================================
ENCRYPTION_KEY=your-encryption-key-here

# ============================================================
# Email Notifications (Gmail)
# ============================================================
# To enable email notifications:
# 1. Use a Gmail account
# 2. Enable 2-factor authentication
# 3. Generate App Password: https://myaccount.google.com/apppasswords
# 4. Use the 16-character app password below

SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-16-char-app-password

# ============================================================
# Database Configuration
# ============================================================
# Options: 'sqlite' or 'supabase'
DATABASE_TYPE=sqlite

# ============================================================
# Supabase Configuration (Optional - for cloud database)
# ============================================================
# Get these from: https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here
# ============================================================
# Security Settings
# ============================================================
# Maximum failed login attempts before lockout
MAX_FAILED_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_DURATION=15

# ============================================================
# Rate Limiting
# ============================================================
# Format: "number per period"
# Periods: second, minute, hour, day
RATELIMIT_DEFAULT=200 per day, 50 per hour
RATELIMIT_LOGIN=5 per minute
RATELIMIT_UPLOAD=10 per minute

# ============================================================
# WebSocket Configuration
# ============================================================
# CORS allowed origins (comma-separated)
SOCKETIO_CORS_ORIGINS=*

# Async mode: threading, eventlet, gevent
SOCKETIO_ASYNC_MODE=threading

# ============================================================
# Analytics Configuration
# ============================================================
# Default analytics period in days
ANALYTICS_DEFAULT_PERIOD=30

# Cache TTL in seconds
ANALYTICS_CACHE_TTL=300

# ============================================================
# Search Configuration
# ============================================================
# Maximum search results
SEARCH_MAX_RESULTS=100

# Search suggestion limit
SEARCH_SUGGESTION_LIMIT=10

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=vaultx.log

# ============================================================
# Production Settings
# ============================================================
# Set to False in production
DEBUG=True

# Set to True in production with HTTPS
SESSION_COOKIE_SECURE=False

# Session lifetime in seconds (24 hours)
PERMANENT_SESSION_LIFETIME=86400

# ============================================================
# Notes
# ============================================================
# 1. Never commit this file with real credentials
# 2. Copy this file to .env and fill in your values
# 3. Keep .env in .gitignore
# 4. Use strong, unique passwords
# 5. Rotate keys regularly in production
